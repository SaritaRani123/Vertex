// Prisma 7 - uses prisma-client provider with required output
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===============================
// ENUMS
// ===============================

enum program_status {
  ACTIVE
  INACTIVE
}

enum course_status {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum semester_type {
  FALL
  WINTER
  SUMMER
}

// ===============================
// MODELS
// ===============================

model departments {
  id          String     @id @default(uuid())
  name        String     @unique
  code        String     @unique

  programs    programs[]

  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt

  @@index([code])
}

// --------------------------------

model programs {
  id              String          @id @default(uuid())
  name            String
  code            String          @unique
  duration_years  Int
  status          program_status  @default(ACTIVE)

  department_id   String
  department      departments     @relation(fields: [department_id], references: [id], onDelete: Restrict)

  courses         courses[]

  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  @@index([department_id])
  @@unique([name, department_id])
}

// --------------------------------

model courses {
  id              String          @id @default(uuid())
  name            String
  code            String          @unique
  description     String?

  prerequisites   String[]

  credits         Int
  lecture_hours   Int
  lab_hours       Int

  status          course_status   @default(ACTIVE)

  program_id      String
  program         programs        @relation(fields: [program_id], references: [id], onDelete: Restrict)

  terms           terms[]

  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  @@index([program_id])
  @@index([status])
}

// --------------------------------

model semesters {
  id          String         @id @default(uuid())
  year        Int
  type        semester_type

  terms       terms[]

  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt

  @@unique([year, type])
  @@index([year])
}

// --------------------------------
// BRIDGE TABLE
// --------------------------------

model terms {
  id            String     @id @default(uuid())

  semester_id   String
  semester      semesters  @relation(fields: [semester_id], references: [id], onDelete: Cascade)

  course_id     String
  course        courses    @relation(fields: [course_id], references: [id], onDelete: Cascade)

  created_at    DateTime   @default(now())

  @@unique([semester_id, course_id])
  @@index([semester_id])
  @@index([course_id])
}
